<UserControl x:Class="MiniRPG.Views.UpgradeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">

    <Grid Background="#111111">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">

            <!-- MONETE -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="{Binding PlayerCoins}"
                           Foreground="Gold"
                           FontSize="20"/>
                <Image Source="pack://application:,,,/Assets/Sprites/UI/coin.png"
                       Width="24" Height="24"/>
            </StackPanel>
            <TextBlock Text="Upgrade"
                       Foreground="White"
                       FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"
                       />

            <!-- UPGRADE DANNO -->
            <StackPanel Margin="0,10">
                <TextBlock Text="{Binding DamageLevelText}"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,5"/>

                <Button Command="{Binding UpgradeDamageCommand}" Height="40" Foreground="Black" Background="#FF444444">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Danno (+3)" Foreground="White" FontSize="16" Margin="0,0,10,0"/>
                        <Image Source="pack://application:,,,/Assets/Sprites/UI/coin.png"
                               Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding DamageCost}" Foreground="Gold" FontSize="16"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- UPGRADE VITA -->
            <StackPanel Margin="0,10">
                <TextBlock Text="{Binding HealthLevelText}"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,5"/>

                <Button Command="{Binding UpgradeHealthCommand}" Height="40" Background="#FF444444">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Vita (+10)" Foreground="White" FontSize="16" Margin="0,0,10,0"/>
                        <Image Source="pack://application:,,,/Assets/Sprites/UI/coin.png"
                               Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding HealthCost}" Foreground="Gold" FontSize="16"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- UPGRADE VELOCITÀ -->
            <StackPanel Margin="0,10">
                <TextBlock Text="{Binding SpeedLevelText}"
                           Foreground="White"
                           FontSize="16"
                           Margin="0,0,0,5"/>

                <Button Command="{Binding UpgradeSpeedCommand}" Height="40" Background="#FF444444">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Velocità (+5)" Foreground="White" FontSize="16" Margin="0,0,10,0"/>
                        <Image Source="pack://application:,,,/Assets/Sprites/UI/coin.png"
                               Width="20" Height="20" Margin="0,0,5,0"/>
                        <TextBlock Text="{Binding SpeedCost}" Foreground="Gold" FontSize="16"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button Content="Continua"
                    Margin="0,30,0,0"
                    Height="40"
                    Click="ContinueButton_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
