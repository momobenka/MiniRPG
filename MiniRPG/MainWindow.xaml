<Window x:Class="MiniRPG.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MiniRPG.Views"
        mc:Ignorable="d"
        Title="MiniRPG" Height="600" Width="800" WindowStartupLocation="CenterScreen">
    <Grid x:Name="RootGrid" Background="Black">
        <!-- Home -->
        <Grid x:Name="HomeScreen">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="MiniRPG" Foreground="White" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <Button Content="Start" Width="120" Height="40" Click="StartButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- Contenitore dinamico per Game / Upgrade -->
        <ContentControl x:Name="ContentHost" Visibility="Collapsed"/>
    </Grid>
</Window>
